# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, never exposed to browser

# Geolocation IP fallback — used client-side when browser permission is denied
NEXT_PUBLIC_GEO_API_URL=https://ip-api.com/json

# Rate limiting
RATE_LIMIT_CONTRIBUTE_RPM=5       # max contribution submissions per IP per minute
RATE_LIMIT_FP_RPM=10              # max first-principles requests per IP per minute
RATE_LIMIT_VOICES_RPM=30          # max voices fetches per IP per minute
MAX_DAILY_CONTRIBUTIONS=3         # max contributions per visitor per 24h

# Earth visualization threshold
MAX_EARTH_FILL_CONTRIBUTIONS=10000

# Mission hue assignment — Claude Haiku via Anthropic API (~$0.00004/submission)
ANTHROPIC_API_KEY=                # falls back to warm gold (hue 45) if unset

# Analytics — Plausible (self-hosted or cloud at https://plausible.io)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=wherearewegoing.earth

# Capture page — set to "true" to enable /capture in production (used by npm run capture)
ENABLE_CAPTURE_PAGE=

# Error tracking — Sentry (https://sentry.io)
# NEXT_PUBLIC_SENTRY_DSN is used by both client and server (DSN is not secret)
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG and SENTRY_PROJECT are only needed for source-map uploads in CI
SENTRY_ORG=
SENTRY_PROJECT=
